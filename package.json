{
  "name": "@firmis/ai-inventory",
  "version": "0.1.0",
  "description": "Detect AI frameworks, LLM dependencies, and model files in any project. One command to know what AI is in your codebase.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ai-inventory": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "ai-inventory",
    "ai-detection",
    "llm",
    "machine-learning",
    "framework-detection",
    "model-detection",
    "dependency-detection",
    "langchain",
    "openai",
    "anthropic",
    "mcp",
    "crewai",
    "autogen",
    "huggingface",
    "gguf",
    "safetensors",
    "sbom",
    "supply-chain"
  ],
  "author": "Firmis Labs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/firmislabs/ai-inventory.git"
  },
  "bugs": {
    "url": "https://github.com/firmislabs/ai-inventory/issues"
  },
  "homepage": "https://github.com/firmislabs/ai-inventory#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  }
}
